  },
  "api_endpoints": {
    "base_url": "http://72.56.65.226:8001/api/",
    "authentication": {
      "register": "POST /auth/register/",
      "login": "POST /auth/login/",
      "google_auth": "POST /auth/google/",
      "token_refresh": "POST /auth/token/refresh/",
      "me": "GET /auth/me/",
      "update_profile": "PATCH /auth/me/"
    },
    "budgets": {
      "list": "GET /budgets/",
      "create": "POST /budgets/",
      "detail": "GET /budgets/{id}/",
      "update": "PATCH /budgets/{id}/",
      "delete": "DELETE /budgets/{id}/",
      "members": "GET /budgets/{id}/members/",
      "create_invite": "POST /budgets/{id}/invites/",
      "join": "POST /budgets/join/"
    },
    "categories": {
      "list": "GET /categories/?budget={id}",
      "create": "POST /categories/",
      "detail": "GET /categories/{id}/",
      "update": "PATCH /categories/{id}/",
      "delete": "DELETE /categories/{id}/"
    },
    "transactions": {
      "list": "GET /transactions/?budget={id}",
      "create": "POST /transactions/",
      "detail": "GET /transactions/{id}/",
      "update": "PATCH /transactions/{id}/",
      "delete": "DELETE /transactions/{id}/"
    }
  },
  "migrations": {
    "0001_initial": {
      "description": "Initial database schema with all models",
      "created": "2026-04-23"
    },
    "0002_remove_user_default_budget": {
      "description": "Remove default_budget field from User model",
      "created": "2026-04-23"
    }
  }
}
